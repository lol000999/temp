server {
    listen 80;
    server_name lol000999m-kuma.serverpit.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name lol000999m-kuma.serverpit.com;

    ssl_certificate /etc/letsencrypt/live/lol000999m-kuma.serverpit.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lol000999m-kuma.serverpit.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3001;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name lol000999m-code.serverpit.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name lol000999m-code.serverpit.com;

    ssl_certificate /etc/letsencrypt/live/lol000999m-code.serverpit.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lol000999m-code.serverpit.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3002;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name lol000999m-mccontrol.serverpit.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name lol000999m-mccontrol.serverpit.com;

    ssl_certificate /etc/letsencrypt/live/lol000999m-mccontrol.serverpit.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lol000999m-mccontrol.serverpit.com/privkey.pem;

    location / {
        proxy_pass https://127.0.0.1:3003;

	proxy_ssl_verify off;
	proxy_ssl_server_name on;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
